# EmailJS (for consultation form email notifications)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key

# CRM integration — set to your deployed CRM URL after deploying tullia-crm
NEXT_PUBLIC_CRM_INTAKE_URL=https://your-crm.vercel.app/api/intake
